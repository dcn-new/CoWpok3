# Include the following configuration files
include ~/.config/i3/keybinds.conf

# --- Startup and services---
# Set wallpaper
exec --no-startup-id feh --bg-fill ~/Pictures/renaissance-art-collection/the-barque-of-dante-dante-and-virgil-in-the-underworld.jpg

# Start pipewire services
exec --no-startup-id pipewire &

# --- Automated Security Timeout (900 Seconds / 15 Minutes) ---
exec --no-startup-id xset s 900
exec --no-startup-id xss-lock -- i3lock -i ~/Pictures/your_wallpaper.png

# --- Appearance ---
# Set gap widths
#gaps inner 10
#gaps outer 10

# Set border style and width
default_border normal 2
default_floating_border normal
hide_edge_borders smart_no_gaps
hide_edge_borders vertical

# Set titlebar font
font pango:Terminus 16px

# class                 border  backgr. text    indicator child_border
client.focused          #1494f3 #016fc2 #ffffff #2e9ef4   #222222
client.focused_inactive #ffffff #c3c3c3 #070707 #222222   #222222
client.unfocused        #929294 #505050 #c3c3c3 #222222   #222222
client.urgent           #2f343a #900000 #ffffff #222222   #222222
client.placeholder      #000000 #0c0c0c #ffffff #222222   #222222

# --- Window Rules ---
for_window [class="Firefox" title="Picture-in-Picture"] floating enable
for_window [class="hud-floating"] floating enable, border normal, resize set 680 480, move position center
for_window [class="hud-monitor"] floating enable, border normal, resize set 400 400

# i3bar and 13status Configuration
bar {
        position bottom
        status_command i3status

        font pango:terminus
        workspace_buttons yes
        strip_workspace_numbers yes
}
